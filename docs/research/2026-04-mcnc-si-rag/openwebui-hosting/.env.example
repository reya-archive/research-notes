# ==============================================================================
# MCNC SI RAG - openwebui-hosting 환경 변수
# ==============================================================================
# 이 파일을 `.env` 로 복사한 뒤 실제 값으로 채워넣으세요.
#   cp .env.example .env
# .env 는 절대 커밋하지 마세요 (.gitignore 에 이미 포함).
# ==============================================================================

# ------------------------------------------------------------------------------
# AWS Bedrock (필수)
# ------------------------------------------------------------------------------
# 도쿄 리전에서 Claude Sonnet 4.x, Haiku 4.5, Titan Embeddings v2 모델이
# ACTIVE 상태여야 합니다. 자세한 체크리스트는 docs/01-prerequisites.md 참고.
AWS_REGION=ap-northeast-1

# IAM Programmatic access key. 콘솔 IAM → 사용자 → 보안자격증명 에서 발급.
# 필요 권한: bedrock:InvokeModel, bedrock:InvokeModelWithResponseStream
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------------------
# LiteLLM Proxy 인증 (필수)
# ------------------------------------------------------------------------------
# Open WebUI 등 OpenAI 호환 클라이언트가 Bearer 토큰으로 보낼 값입니다.
# 프록시는 이 값이 일치할 때만 Bedrock 으로 릴레이합니다.
#
# 생성 예:
#   openssl rand -hex 32
#   python -c "import secrets; print('sk-' + secrets.token_urlsafe(32))"
#
# "sk-" 접두사는 관습상 붙이며 필수는 아닙니다.
LITELLM_MASTER_KEY=sk-change-me-to-a-long-random-string

# ------------------------------------------------------------------------------
# Open WebUI (필수)
# ------------------------------------------------------------------------------
# 세션 · JWT 서명용 비밀키. 미설정 시 컨테이너가 랜덤 생성하지만, 재시작할
# 때마다 모든 세션이 만료되므로 반드시 고정 값으로 지정하세요.
#
# 생성 예:
#   openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# Open WebUI 상단에 표시될 서비스 이름. 기존 mcnc-llm-webui 와 시각 분리 용도.
WEBUI_NAME=MCNC RAG Lab

# ------------------------------------------------------------------------------
# 호스트 바인딩 포트 (충돌 회피)
# ------------------------------------------------------------------------------
# 이 서버는 이미 아래 포트들이 사용 중입니다 (2026-04 현재):
#   80/443 nginx(Dify)       3000 mcnc-llm-webui       4000 gitlab
#   5003 dify-plugin         7000/7010/7020/7080 mcnc-rag-*
#   15432 mcnc-rag-postgre
#
# 이 번들은 기본적으로 위와 겹치지 않게 14000 / 13000 을 씁니다.
# 필요 시 이 값만 바꿔도 됩니다 (컨테이너 내부 포트는 4000 / 8080 고정).
LITELLM_PORT=14000
OPENWEBUI_PORT=13000

# ==============================================================================
# 참고용 - litellm_config.yaml 에 이미 박혀 있는 모델 정보 (컨테이너는 읽지 않음)
# ==============================================================================
# Claude 4.x 는 직접 model ID 로 on-demand 호출이 막혀 있고, 반드시
# "Inference Profile ID" 로 불러야 합니다. prefix 에 따라 데이터 상주와 쿼터
# 풀이 달라짐:
#   jp.      → 도쿄 리전 내 고정 (데이터 상주 최우선, 일일 토큰 쿼터 가장 타이트)
#   apac.    → 아시아-태평양 크로스 리전 (중간 타협점)
#   global.  → 전 세계 크로스 리전 (쿼터 가장 여유, 데이터는 미국까지 흐를 수 있음)
#
# ⚠ 이 번들 기본 설정은 시연 · 검증 단계를 위해 `global.` 입니다
#    (신규 계정의 jp. 일일 토큰 쿼터가 바로 막히는 문제 회피).
#    실 운영 투입 전에는 데이터 상주 요건을 재검토하고 jp. 또는 apac. 로
#    일괄 교체하세요 (docs/01-prerequisites.md 의 "운영 전환 체크리스트").
#
# ap-northeast-1 에서 현재 번들이 사용하는 프로필 (2026-04 기준):
#   global.anthropic.claude-sonnet-4-6                       (권장 · 최신)
#   global.anthropic.claude-sonnet-4-5-20250929-v1:0         (주석, 필요 시 해제)
#   global.anthropic.claude-haiku-4-5-20251001-v1:0          (주석, 저렴한 대안)
#
# 클라이언트가 호출할 때 쓰는 model 이름은 litellm_config.yaml 의 model_name
# (예: "claude-sonnet-4-6") 이며, LiteLLM 이 자동으로 위 프로필 ID 로 변환합니다.
