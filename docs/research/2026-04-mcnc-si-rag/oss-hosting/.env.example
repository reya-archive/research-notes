# ==============================================================================
# MCNC SI RAG - Dify + Bedrock 프로토타입 환경 변수
# ==============================================================================
# 이 파일을 `.env` 로 복사한 뒤 실제 값으로 채워넣으세요.
#   cp .env.example .env
# .env 는 절대 커밋하지 마세요 (.gitignore 에 이미 포함).
# ==============================================================================

# ------------------------------------------------------------------------------
# Docker Compose 프로필 (필수)
# ------------------------------------------------------------------------------
# Dify 1.x 의 compose 는 db_postgres, weaviate 등 일부 핵심 서비스를 profile 뒤에
# 숨겨두고 COMPOSE_PROFILES 로 활성화하는 구조입니다. 이 값이 비면 api 가 DB 를
# 찾지 못해 "could not translate host name db_postgres" 로 무한 재시작합니다.
# 기본값 그대로 두세요 (단일 VM 내장 DB + Weaviate 사용).
COMPOSE_PROFILES=weaviate,postgresql

# ------------------------------------------------------------------------------
# AWS Bedrock (필수)
# ------------------------------------------------------------------------------
# 도쿄 리전에서 Claude Sonnet 계열, Titan Embeddings v2 모델이 ACTIVE 상태여야
# 합니다. 자세한 체크리스트는 docs/01-prerequisites.md 참고.
AWS_REGION=ap-northeast-1

# --- 인증 방식 A) IAM Access Key (Dify 기본 지원, 권장) -----------------------
# 콘솔 IAM 에서 Programmatic access key 발급 후 기입.
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 인증 방식 B) Bedrock API Key (2025 신규 기능, 선택) ----------------------
# 콘솔 Bedrock → API keys 에서 발급. 'bedrock-api-key-...' 로 시작.
# - Long-term : 만료 없음. 시연·운영 권장.
# - Short-term: 12시간 만료 + 일일 토큰 쿼터 제한. 호출 테스트용.
# Dify 플러그인 버전에 따라 이 필드를 지원하지 않을 수 있습니다
# (Dify 1.0 기준 Bedrock provider 는 A) 방식만 사용).
# 지원되지 않으면 A) 만 채우고 이 줄은 비워두세요.
AWS_API_KEY=

# ------------------------------------------------------------------------------
# 참고용 - Dify UI Model Provider 에 입력할 값 (컨테이너에서 읽지 않음)
# ------------------------------------------------------------------------------
# Claude 4.x 는 직접 model ID 로 on-demand 호출이 막혀 있고, 반드시
# "Inference Profile ID" 로 불러야 합니다. prefix 에 따라 데이터 상주가 달라짐:
#   jp.      → 도쿄 리전 내 고정       (데이터 주권 최우선 권장)
#   apac.    → 아시아-태평양 크로스 리전
#   global.  → 전 세계 크로스 리전
#
# ap-northeast-1 에서 검증된 ACTIVE 프로필 (2026-04 기준):
#   jp.anthropic.claude-sonnet-4-6                      (권장 · 최신)
#   jp.anthropic.claude-sonnet-4-5-20250929-v1:0
#   jp.anthropic.claude-haiku-4-5-20251001-v1:0         (저렴한 대안)
BEDROCK_LLM_MODEL=jp.anthropic.claude-sonnet-4-6

# 임베딩은 inference profile 불필요 - 직접 model ID 로 호출.
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0

# ------------------------------------------------------------------------------
# Ollama (setup.sh --with-ollama 사용 시만)
# ------------------------------------------------------------------------------
# 호스트에 네이티브로 설치된 Ollama 를 Dify 에 연결할 때 사용.
# Dify api/worker 컨테이너가 "host.docker.internal" 이름으로 호스트를 바라볼
# 수 있도록 compose.ollama.yml 이 host-gateway 매핑을 추가합니다.
#
# - Ollama 는 반드시 OLLAMA_HOST=0.0.0.0:11434 로 리슨해야 합니다
#   (기본 127.0.0.1 만 리슨하면 컨테이너에서 접근 불가)
# - LLM + 임베딩을 모두 같은 Ollama 인스턴스에서 불러 씁니다

# Dify UI 의 Ollama 프로바이더 Setup 에 입력할 Base URL (참고용, 컨테이너 환경변수 아님)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# 참고용 - Dify UI 에 입력할 모델명 (값 자체는 컨테이너에서 읽지 않음)
OLLAMA_LLM_MODEL=gemma4:26b
OLLAMA_EMBED_MODEL=bge-m3
